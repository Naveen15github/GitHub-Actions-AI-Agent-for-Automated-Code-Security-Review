# =============================================================================
# GitHub AI Code Reviewer — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit your .env file to Git. It is already in .gitignore.
# =============================================================================


# ── OpenRouter API Keys ───────────────────────────────────────────────────────
# Get your free keys at https://openrouter.ai → Account → API Keys
# The agent will automatically rotate through these keys if one hits a rate
# limit (HTTP 429) or runs out of credits (HTTP 402).
# At least ONE key is required. Keys 2 and 3 are optional but recommended.

OPENROUTER_API_KEY_1=your-key-here-from-openrouter-dot-ai
OPENROUTER_API_KEY_2=optional-second-key-for-rate-limit-fallback
OPENROUTER_API_KEY_3=optional-third-key-for-additional-backup


# ── OpenRouter Model Configuration ───────────────────────────────────────────
# The LLM model to use. The default is free and high-quality.
# See https://openrouter.ai/models for alternatives.

OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Optional: used in HTTP-Referer and X-Title headers sent to OpenRouter
OPENROUTER_HTTP_REFERER=https://github.com/your-org/your-repo
OPENROUTER_APP_TITLE=GitHub AI Code Reviewer


# ── GitHub Configuration ──────────────────────────────────────────────────────
# In GitHub Actions, GITHUB_TOKEN is provided automatically — you don't need
# to set it manually there. Only needed for local testing.
#
# To generate a personal access token for local testing:
#   GitHub → Settings → Developer Settings → Personal Access Tokens → Tokens (classic)
#   Scopes needed: repo (full), pull_requests (write)

GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PR context — these are injected automatically by GitHub Actions.
# For local testing via scripts/test_local.py, pass a PR URL as an argument
# instead of setting these manually.

PR_NUMBER=1
REPO_OWNER=your-github-username-or-org
REPO_NAME=your-repository-name


# ── Slack Configuration ───────────────────────────────────────────────────────
# Incoming webhook URL for Slack notifications on high-risk PRs.
# Leave empty or unset to disable Slack notifications entirely.
#
# To get a webhook URL:
#   1. Go to https://api.slack.com/apps → Create New App → From scratch
#   2. Enable "Incoming Webhooks" under Features
#   3. Click "Add New Webhook to Workspace" and choose a channel
#   4. Copy the webhook URL below

SLACK_WEBHOOK_URL=your-slack-webhook-url-here-or-leave-empty

# ── Agent Thresholds ──────────────────────────────────────────────────────────
# risk_score >= RISK_THRESHOLD will trigger a Slack notification.
# Default: 50 (scores 50–100 send an alert)

RISK_THRESHOLD=50

# Maximum approximate token budget for the PR diff sent to the LLM.
# Diffs exceeding this are truncated. Default: 12000 tokens (~48 KB of diff text)

MAX_DIFF_TOKENS=12000
